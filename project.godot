; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SchoolGame"
run/main_scene="res://scenes/test_scene.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/icons/ui/godot_icon.svg"

[audio]

buses/default_bus_layout="uid://cqq4qhl0el65u"

[autoload]

DialogueManager="*uid://c2jwbm0wee7j6"
EventManager="*uid://dl1lgen8y5dsu"
GameManager="*uid://cmd1u5c4mp5gs"
InputManager="*uid://8vassbp55tau"
InventoryManager="*uid://bgltkoojbqj2i"
SignalBus="*uid://ddt7dkbp124a8"
PhantomCameraManager="*uid://duq6jhf6unyis"
QuestManager="*uid://brbfflif4pr84"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/vsync/vsync_mode=3

[editor_plugins]

enabled=PackedStringArray("res://addons/phantom_camera/plugin.cfg")

[global_group]

player="Игрок"
collectable=""
player_ui=""
player_camera=""

